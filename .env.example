# PostgreSQL (recommended for Hostinger VPS production)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=sdo_user
PGPASSWORD=sdo_pass
PGDATABASE=sdo_attendance

# Optional single-string alternative to PGHOST/PGPORT/...
DATABASE_URL=

# Optional fallback JSON DB file path when PostgreSQL is not configured
DB_PATH=./data/db.json

ALLOW_SEED=true
